# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
# Base URL of this Next.js app (used for reference; OAuth return uses the URL you opened).
# Supabase Auth → URL Configuration → Redirect URLs MUST include this origin, e.g.:
#   http://localhost:3000/**
#   http://127.0.0.1:3000/**
# plus production (https://yourdomain.com/**) or Supabase will fall back to "Site URL" (often prod).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (configured in Supabase dashboard)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (for promotions — future)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
